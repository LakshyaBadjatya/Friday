# LLM provider: nvidia | fake
FRIDAY_LLM_PROVIDER=fake
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# Per-request LLM timeout in seconds (hard budget; provider does not retry).
# 120s absorbs NVIDIA cold-start latency on heavier generation (e.g. 3D studio).
FRIDAY_LLM_TIMEOUT_SECONDS=120.0
# Routing
FRIDAY_ROUTE_MIN_CONFIDENCE=0.55
# Memory
FRIDAY_MEMORY_AUTOWRITE=true
# Persona
FRIDAY_OWNER_ADDRESS=Boss
# Feature flags (default off)
FRIDAY_ENABLE_VOICE=false
FRIDAY_ENABLE_HOME=false
FRIDAY_TTS_PROVIDER=piper
FRIDAY_WAKE_WORD_ENGINE=openwakeword
# Device control (comma-separated allow-list of actuatable device ids)
FRIDAY_DEVICE_ALLOWLIST=
# Alerting (dedupe + rate-limit identical alerts within this window)
FRIDAY_ALERT_RATE_LIMIT_SECONDS=300.0
FRIDAY_ALERT_DEDUPE=true
# Logging
FRIDAY_LOG_LEVEL=INFO
FRIDAY_LOG_JSON=true
# LLM fallback provider: none | gemini (FallbackLLM secondary; only active when
# a Gemini key is present, otherwise single-provider behaviour is kept)
FRIDAY_LLM_FALLBACK_PROVIDER=none
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-2.0-flash
# 3D Studio (Phase 7; default off). When enabled, open /studio. The free
# procedural path uses the existing LLM (no extra key). The optional hi-fi
# external backend is keyless-safe and falls back to procedural.
FRIDAY_ENABLE_STUDIO=false
# Hi-fi text-to-3D backend: none | meshy (only active when MESHY_API_KEY is set;
# otherwise generation falls back to the free procedural Scene path)
FRIDAY_STUDIO_HIFI_PROVIDER=none
MESHY_API_KEY=
FRIDAY_STUDIO_HIFI_MODEL=
# Gateway hardening (Phase 6). Default off keeps the local-first gateway open.
# When require_auth is true, every route except /health needs
# `Authorization: Bearer <key>` with <key> in the comma-separated FRIDAY_API_KEYS.
FRIDAY_REQUIRE_AUTH=false
FRIDAY_API_KEYS=
# Fixed-window rate limit per client (bearer key if present, else client IP):
# at most FRIDAY_RATE_LIMIT_REQUESTS per FRIDAY_RATE_LIMIT_WINDOW_SECONDS; over
# the limit -> 429 with Retry-After. /health is exempt. Toggle via
# FRIDAY_RATE_LIMIT_ENABLED.
FRIDAY_RATE_LIMIT_ENABLED=true
FRIDAY_RATE_LIMIT_REQUESTS=60
FRIDAY_RATE_LIMIT_WINDOW_SECONDS=60.0
# Personal RAG (Tier 1; default off). When enabled, POST /rag/ingest a note or a
# file; the document is chunked into the shared vector store and becomes
# answerable via the existing Knowledge path with citations. GET /rag/sources
# lists ingested docs; DELETE /rag/sources/{id} forgets one. PDF reading is
# optional and lazy (requires `pip install pypdf`, intentionally not a dependency).
FRIDAY_ENABLE_RAG=false
# Document chunking: target chunk size (chars) and inter-chunk overlap. Overlap
# keeps a fact spanning a chunk boundary retrievable from at least one chunk.
FRIDAY_RAG_CHUNK_SIZE=800
FRIDAY_RAG_CHUNK_OVERLAP=120
# Reminders & tasks (Tier 1; default off). When enabled, manage reminders over
# the REST surface: POST /reminders {text, due_at?, recurrence?}, GET
# /reminders?status=open|all, POST /reminders/{id}/complete, DELETE
# /reminders/{id}. Reminders are stored in a sibling SQLite file alongside
# FRIDAY_MEMORY_DB_PATH and are also creatable/listable/completable by the
# Automation agent via the tool registry. Recurrence (daily|weekly) rolls a
# reminder's due date forward by one period on completion (keeping it open).
FRIDAY_ENABLE_REMINDERS=false
