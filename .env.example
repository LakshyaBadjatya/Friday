# LLM provider: nvidia | fake
FRIDAY_LLM_PROVIDER=fake
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# Per-request LLM timeout in seconds (hard budget; provider does not retry).
# 120s absorbs NVIDIA cold-start latency on heavier generation (e.g. 3D studio).
FRIDAY_LLM_TIMEOUT_SECONDS=120.0
# Routing
FRIDAY_ROUTE_MIN_CONFIDENCE=0.55
# Memory
FRIDAY_MEMORY_AUTOWRITE=true
# Persona
FRIDAY_OWNER_ADDRESS=Boss
# Feature flags (default off)
FRIDAY_ENABLE_VOICE=false
FRIDAY_ENABLE_HOME=false
FRIDAY_TTS_PROVIDER=piper
FRIDAY_WAKE_WORD_ENGINE=openwakeword
# Device control (comma-separated allow-list of actuatable device ids)
FRIDAY_DEVICE_ALLOWLIST=
# Alerting (dedupe + rate-limit identical alerts within this window)
FRIDAY_ALERT_RATE_LIMIT_SECONDS=300.0
FRIDAY_ALERT_DEDUPE=true
# Logging
FRIDAY_LOG_LEVEL=INFO
FRIDAY_LOG_JSON=true
# LLM fallback provider: none | gemini (FallbackLLM secondary; only active when
# a Gemini key is present, otherwise single-provider behaviour is kept)
FRIDAY_LLM_FALLBACK_PROVIDER=none
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-2.0-flash
# 3D Studio (Phase 7; default off). When enabled, open /studio. The free
# procedural path uses the existing LLM (no extra key). The optional hi-fi
# external backend is keyless-safe and falls back to procedural.
FRIDAY_ENABLE_STUDIO=false
# Hi-fi text-to-3D backend: none | meshy (only active when MESHY_API_KEY is set;
# otherwise generation falls back to the free procedural Scene path)
FRIDAY_STUDIO_HIFI_PROVIDER=none
MESHY_API_KEY=
FRIDAY_STUDIO_HIFI_MODEL=
# Gateway hardening (Phase 6). Default off keeps the local-first gateway open.
# When require_auth is true, every route except /health needs
# `Authorization: Bearer <key>` with <key> in the comma-separated FRIDAY_API_KEYS.
FRIDAY_REQUIRE_AUTH=false
FRIDAY_API_KEYS=
# Fixed-window rate limit per client (bearer key if present, else client IP):
# at most FRIDAY_RATE_LIMIT_REQUESTS per FRIDAY_RATE_LIMIT_WINDOW_SECONDS; over
# the limit -> 429 with Retry-After. /health is exempt. Toggle via
# FRIDAY_RATE_LIMIT_ENABLED.
FRIDAY_RATE_LIMIT_ENABLED=true
FRIDAY_RATE_LIMIT_REQUESTS=60
FRIDAY_RATE_LIMIT_WINDOW_SECONDS=60.0
# Personal RAG (Tier 1; default off). When enabled, POST /rag/ingest a note or a
# file; the document is chunked into the shared vector store and becomes
# answerable via the existing Knowledge path with citations. GET /rag/sources
# lists ingested docs; DELETE /rag/sources/{id} forgets one. PDF reading is
# optional and lazy (requires `pip install pypdf`, intentionally not a dependency).
FRIDAY_ENABLE_RAG=false
# Document chunking: target chunk size (chars) and inter-chunk overlap. Overlap
# keeps a fact spanning a chunk boundary retrievable from at least one chunk.
FRIDAY_RAG_CHUNK_SIZE=800
FRIDAY_RAG_CHUNK_OVERLAP=120
# Reminders & tasks (Tier 1; default off). When enabled, manage reminders over
# the REST surface: POST /reminders {text, due_at?, recurrence?}, GET
# /reminders?status=open|all, POST /reminders/{id}/complete, DELETE
# /reminders/{id}. Reminders are stored in a sibling SQLite file alongside
# FRIDAY_MEMORY_DB_PATH and are also creatable/listable/completable by the
# Automation agent via the tool registry. Recurrence (daily|weekly) rolls a
# reminder's due date forward by one period on completion (keeping it open).
FRIDAY_ENABLE_REMINDERS=false
# Meeting capture (Tier 1; default off). When enabled, POST /meetings/capture
# with {title, audio_b64} JSON or a multipart audio upload: the audio is
# transcribed (FakeSTT unless voice is configured, else Whisper), summarized by
# one NON-FATAL LLM pass (any error -> transcript-only notes, action_items []),
# optionally ingested into the shared vector store (when FRIDAY_ENABLE_RAG is on,
# so the meeting is answerable via the Knowledge path), then stored. GET /meetings
# lists notes; GET /meetings/{id} fetches one; DELETE /meetings/{id} removes one.
# Notes are stored in a sibling SQLite file alongside FRIDAY_MEMORY_DB_PATH.
FRIDAY_ENABLE_MEETINGS=false
# Agent reach (Tier 1; default off). When enabled, the read-only `agent_reach`
# tool is registered and added to the Research/Knowledge agents' allow-lists.
# read_url fetches a FULL page as clean markdown via the keyless Jina Reader
# (FRIDAY_AGENT_REACH_JINA_BASE, GET {base}{url}); it needs no binary. transcribe
# shells out to the isolated `agent-reach` CLI (install once via
# `uv tool install git+https://github.com/Panniantong/agent-reach` — deliberately
# NOT a FRIDAY dependency); a missing CLI degrades cleanly with an install hint.
# Read-only: never fabricates content on error. FRIDAY_AGENT_REACH_TIMEOUT is the
# per-request budget (seconds) for both the Jina GET and the CLI run.
FRIDAY_ENABLE_AGENT_REACH=false
FRIDAY_AGENT_REACH_JINA_BASE=https://r.jina.ai/
FRIDAY_AGENT_REACH_TIMEOUT=60.0
# Scheduled triggers (Tier 1; default off). When enabled, manage time-based
# triggers over the REST surface: POST /schedules {name, kind, spec, action,
# enabled?} (kind: interval|once|daily|weekly; spec: interval->seconds,
# once->ISO datetime, daily->"HH:MM", weekly->"DOW HH:MM"), GET /schedules,
# POST /schedules/{id}/enable|disable, POST /schedules/{id}/run (fire now),
# DELETE /schedules/{id}. Triggers fire named actions (e.g. due_reminders,
# noop) and are stored in a sibling SQLite file alongside FRIDAY_MEMORY_DB_PATH.
# A background loop ticks every FRIDAY_SCHEDULER_TICK_SECONDS (only started when
# enabled); next-run math is dependency-free (no cron library).
FRIDAY_ENABLE_SCHEDULER=false
FRIDAY_SCHEDULER_TICK_SECONDS=30.0
# Proactive briefing (Tier 1; default off). When enabled, GET /briefing returns a
# digest assembled from the local stores: due/overdue/upcoming reminders, recent
# tool-call activity, and a one-line metrics summary, with a time-of-day-aware
# greeting addressing FRIDAY_OWNER_ADDRESS. The scheduler "briefing" action builds
# the same digest for utcnow and emits it via the notify sink, so a morning/EOD
# briefing can fire on its own. An optional LLM summary is non-fatal (any LLM
# error falls back to the structured-only briefing). No new store/path is added.
FRIDAY_ENABLE_BRIEFING=false
# How many recent tool-call audit rows the briefing summarizes (one line each).
FRIDAY_BRIEFING_RECENT_ACTIVITY=5
# Auto-journaling (Tier 2; default off). When enabled, POST /journal/build {date?}
# aggregates a day's events (tool-call audit rows + reminders completed that day +
# a one-line metrics summary) into a deterministic JournalEntry and saves it
# (upsert by date); GET /journal lists entries and GET /journal/{date} fetches one.
# The scheduler "journal" action builds + saves the entry for utcnow, so an
# end-of-day journal can write itself. An optional LLM narration is non-fatal (any
# LLM error falls back to a deterministic structured summary). Entries are stored
# in a sibling SQLite file alongside FRIDAY_MEMORY_DB_PATH.
FRIDAY_ENABLE_JOURNAL=false
# Voice protocols (Tier 1; default off). When enabled, define named routines over
# the REST surface: POST /protocols {name, trigger_phrase, steps}, GET /protocols,
# POST /protocols/{id}/run {confirmed?}, DELETE /protocols/{id}. A protocol is an
# ordered list of registered tool calls ({tool, args}) fired by one trigger; it
# runs ONLY registered tools through the existing registry (no arbitrary code) and
# honors the confirm-step — a side-effecting step pauses the run until confirmed.
# The orchestrator also fires a protocol when a turn matches its trigger_phrase or
# "run the <name> protocol". Protocols are stored in a sibling SQLite file
# alongside FRIDAY_MEMORY_DB_PATH.
FRIDAY_ENABLE_PROTOCOLS=false
# Self-critique loop (Tier 2; default off). When enabled, the final persona reply
# is reviewed once before it is returned: a deterministic banned-tone scan (the
# persona's forbidden openers/over-apology/fake-enthusiasm/padding) plus one LLM
# verdict pass asking whether the draft answers the question, avoids fabrication,
# and stays in persona. If it fails and a concrete correction is offered, the
# revision replaces the reply — ONE bounded pass (the revision is never
# re-critiqued) and non-fatal (any critic error keeps the original). Off by
# default adds no extra LLM call to the turn loop.
FRIDAY_ENABLE_SELF_CRITIQUE=false
# Plugins / extensions (Tier 2; default off). When enabled, every *.py file in
# FRIDAY_PLUGINS_DIR (default "plugins/") is loaded at startup and its module-level
# get_tools() tools are registered into the shared tool registry — so plugin tools
# go through the same permission gating + confirm-step as built-ins. Built-in tools
# are registered FIRST and win any name collision (a colliding plugin tool is
# rejected and recorded as that plugin's error). A broken plugin (syntax error,
# missing/raising get_tools()) is captured and skipped, never crashing startup.
# GET /plugins lists what loaded (name, tools, error); it is 404 when disabled.
# CAVEAT: plugins are TRUSTED local code (arbitrary Python the owner drops in, like
# a shell rc) — only install plugins you wrote or fully trust.
FRIDAY_ENABLE_PLUGINS=false
FRIDAY_PLUGINS_DIR=plugins
# Knowledge graph / entity cards (Tier 2; default off). When enabled, FRIDAY keeps
# a tiny knowledge graph of entities (people, projects, orgs, things) and the
# relations between them, persisted in a sibling SQLite file alongside
# FRIDAY_MEMORY_DB_PATH. REST surface: GET /graph/entities?type= lists entities,
# GET /graph/entity/{name} returns an entity card ({entity, relations, facts} —
# facts are the long-term facts that mention the name), and POST /graph/extract
# {text} runs ONE non-fatal LLM pass to pull {entities, relations} from a note and
# applies them to the graph (any LLM/parse error -> empty result, never raises).
# Upserts are idempotent by (name, type); relations by (src, dst, kind). Each
# route is 404 when disabled. No new dependencies.
FRIDAY_ENABLE_KNOWLEDGE_GRAPH=false
# Study / productivity (Tier 2; default off). When enabled, manage spaced-repetition
# flashcards + logged study sessions over the REST surface: POST /study/cards
# {deck, front, back}, GET /study/cards?deck=, GET /study/review (cards due for
# utcnow), POST /study/review/{id} {grade} (grade 0..5 -> SM-2 advances/reschedules
# the card), DELETE /study/cards/{id}, POST /study/sessions {topic, minutes}, GET
# /study/sessions. Scheduling is a pure SM-2 core (1 -> 6 -> round(interval*ease),
# lapse resets, ease floor 1.3). Stored in a sibling SQLite file alongside
# FRIDAY_MEMORY_DB_PATH. Each route is 404 when disabled. No new dependencies.
FRIDAY_ENABLE_STUDY=false
# Hardware / system monitoring (Tier 2; default off). When enabled, GET
# /system/stats returns the host's CPU / memory / disk utilisation (plus optional
# CPU temperature + 1-minute load average) sampled via psutil, and GET
# /system/check returns one alert per breached threshold (empty when healthy). The
# scheduler "system_check" action samples the same monitor and emits any breaches
# via the notify sink, so a proactive resource alert can fire on its own. A metric
# value strictly ABOVE its threshold raises an alert (boundary-equal is healthy);
# optional metrics that are unavailable (None) never breach. Each route is 404 when
# disabled. (psutil is the only new dependency; imported lazily in the real sampler.)
FRIDAY_ENABLE_SYSTEM_MONITOR=false
FRIDAY_SYS_CPU_THRESHOLD=90.0
FRIDAY_SYS_MEM_THRESHOLD=90.0
FRIDAY_SYS_DISK_THRESHOLD=95.0
FRIDAY_SYS_TEMP_THRESHOLD=85.0
