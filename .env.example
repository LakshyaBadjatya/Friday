# LLM provider: nvidia | fake
FRIDAY_LLM_PROVIDER=fake
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# Per-request LLM timeout in seconds (hard budget; provider does not retry)
FRIDAY_LLM_TIMEOUT_SECONDS=60.0
# Routing
FRIDAY_ROUTE_MIN_CONFIDENCE=0.55
# Memory
FRIDAY_MEMORY_AUTOWRITE=true
# Persona
FRIDAY_OWNER_ADDRESS=Boss
# Feature flags (default off)
FRIDAY_ENABLE_VOICE=false
FRIDAY_ENABLE_HOME=false
FRIDAY_TTS_PROVIDER=piper
FRIDAY_WAKE_WORD_ENGINE=openwakeword
# Device control (comma-separated allow-list of actuatable device ids)
FRIDAY_DEVICE_ALLOWLIST=
# Alerting (dedupe + rate-limit identical alerts within this window)
FRIDAY_ALERT_RATE_LIMIT_SECONDS=300.0
FRIDAY_ALERT_DEDUPE=true
# Logging
FRIDAY_LOG_LEVEL=INFO
FRIDAY_LOG_JSON=true
# LLM fallback provider: none | gemini (FallbackLLM secondary; only active when
# a Gemini key is present, otherwise single-provider behaviour is kept)
FRIDAY_LLM_FALLBACK_PROVIDER=none
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-2.0-flash
# 3D Studio (Phase 7; default off). When enabled, open /studio. The free
# procedural path uses the existing LLM (no extra key). The optional hi-fi
# external backend is keyless-safe and falls back to procedural.
FRIDAY_ENABLE_STUDIO=false
# Hi-fi text-to-3D backend: none | meshy (only active when MESHY_API_KEY is set;
# otherwise generation falls back to the free procedural Scene path)
FRIDAY_STUDIO_HIFI_PROVIDER=none
MESHY_API_KEY=
FRIDAY_STUDIO_HIFI_MODEL=
