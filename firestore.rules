rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // A signed-in user may read and write only their own profile document.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Everything else is denied by default. As circle collections (groups,
    // members, status) move into Firestore, add their consent-scoped rules here.
  }
}
