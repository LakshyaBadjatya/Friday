{
  "manifest_version": 3,
  "name": "FRIDAY Quick-Ask",
  "version": "1.0.0",
  "description": "Ask your local FRIDAY from anywhere in the browser.",
  "action": {
    "default_title": "Ask FRIDAY",
    "default_popup": "popup.html"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ]
}
